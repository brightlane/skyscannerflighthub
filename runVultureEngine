// This creates a random footer for every page so every page links to others
const getRandomLinks = (allSlugs, currentSlug) => {
    return allSlugs
        .filter(s => s !== currentSlug)
        .sort(() => 0.5 - Math.random())
        .slice(0, 8); // 8 random internal links per page
};

