name: Daily Article and RSS Feed Generator

on:
  workflow_dispatch:  # This enables the "Run Workflow" button in GitHub Actions
  schedule:
    - cron: "0 0 * * *"  # Automatically runs daily at midnight UTC

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4  # Checkout your repository to access files

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.10"  # You can adjust this to another Python version if necessary

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt  # Install dependencies like GitPython if you have any

      - name: Run article generation script
        run: python article_generator.py  # Run your article generation script (adjust name if different)

      - name: Generate RSS Feed
        run: python rss_feed_generator.py  # Generate the RSS feed using rss_feed_generator.py script

      - name: Commit and push changes
        run: |
          # Configure git
          git config --global user.name "github-actions"
          git config --global user.email "github-actions@github.com"
          
          # Add all changes (new articles + feed.xml)
          git add .
          
          # Check if there are any changes to commit
          if git diff --cached --exit-code; then
            echo "No changes to commit"
          else
            git commit -m "Generate daily articles and update RSS feed"
            git push
          fi
